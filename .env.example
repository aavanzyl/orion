# Postgres connection used by the orchestrator and drizzle-kit
DATABASE_URL=postgres://orion:orion@localhost:5432/orion

# Embedded, zero-setup alternative (no Postgres/Docker needed): runs an
# in-process PGlite database with migrations auto-applied on boot.
# DATABASE_URL=pglite://./.orion/pgdata

# Directory where Orion clones and worktrees managed repositories
ORION_WORKSPACE_DIR=./.orion-workspace

# (Docker only) Host directory bind-mounted into the orchestrator at the same
# absolute path, so `local` and `workspace` projects can reference host paths
# directly. Defaults to your home directory; narrow it if you prefer.
# ORION_PROJECTS_DIR=/Users/you/Documents/Development

# Orchestrator HTTP server
HOST=localhost
PORT=3333

# Max workflow runs executing at once; additional runs are queued and started
# automatically as slots free up. Set to 0 for unlimited. Defaults to 3.
# ORION_MAX_CONCURRENT_RUNS=3

# Codex harness credentials (OpenAI, DeepSeek or other OpenAI-compatible API)
CODEX_API_KEY=
# Optional: point the codex harness at a non-OpenAI, OpenAI-compatible endpoint
# CODEX_BASE_URL=https://api.deepseek.com

# GitHub token used by the scm-github adapter for pushing and opening PRs
GITHUB_TOKEN=

# Optional: POST run lifecycle notifications (approval needed, completed, failed)
# to this webhook URL. Compatible with Slack/Discord incoming webhooks.
# ORION_NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Slack incoming-webhook URL. When set, a `slack` notifier is
# registered so `notify` nodes with `provider: slack` post to this channel.
# ORION_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Public base URL the orchestrator is reachable at. Used to build the MCP SSE
# self-links injected into running agents. Defaults to http://<HOST>:<PORT>.
# ORION_PUBLIC_URL=http://localhost:3333

# Auto-inject the codebase MCP (SSE) into running Orion agents. On by default.
# ORION_CODEBASE_MCP=true

# How often the continuous Linear board sync runs, in milliseconds (default 10m).
# ORION_BOARD_SYNC_INTERVAL_MS=600000

# Optional: salt used to encrypt provider API keys at rest in the database.
# When set, stored provider API keys are encrypted with AES-256-GCM. When unset,
# keys are stored as plaintext.
# PROVIDER_ENCRYPTION_SALT=

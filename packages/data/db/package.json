{
  "name": "@orion/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "tags": ["scope:data", "type:data"],
    "targets": {
      "db:generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "drizzle-kit generate",
          "cwd": "packages/data/db"
        }
      },
      "db:migrate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "drizzle-kit migrate",
          "cwd": "packages/data/db"
        }
      },
      "db:push": {
        "executor": "nx:run-commands",
        "options": {
          "command": "drizzle-kit push",
          "cwd": "packages/data/db"
        }
      }
    }
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.10",
    "@orion/models": "*",
    "drizzle-orm": "^0.44.6",
    "pg": "^8.13.1"
  }
}
